{
  "manifest_version": 3,
  "default_locale": "en",
  "name": "__MSG_extensionName__",
  "version": "0.1.1",
  "description": "__MSG_extensionDescription__",
  "permissions": [
    "clipboardWrite"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://artificialanalysis.ai/*",
        "https://www.artificialanalysis.ai/*"
      ],
      "js": [
        "pareto-core.js",
        "content-script.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "__MSG_actionTitle__",
    "default_icon": {
      "128": "assets/pareto-icon-128.png"
    }
  },
  "icons": {
    "128": "assets/pareto-icon-128.png"
  }
}
